# ============================================================
# ZeroPoint — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── MongoDB Atlas ─────────────────────────────────────────
# Free-tier cluster URI from: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=zeropoint

# ── API Keys ──────────────────────────────────────────────
SHODAN_API_KEY=your_shodan_api_key_here

# Optional — improves Subfinder source coverage
GITHUB_TOKEN=ghp_xxxxxxxxxxxx
VIRUSTOTAL_KEY=your_virustotal_key_here
CENSYS_ID=your_censys_id
CENSYS_SECRET=your_censys_secret

# ── Notifications (at least one recommended) ──────────────
# Discord: Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxx/yyyy

# Telegram: BotFather to create bot, get chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxyz
TELEGRAM_CHAT_ID=-1001234567890

# ── Tool Binary Paths ─────────────────────────────────────
# Only set these if the binaries are not on your PATH
# SUBFINDER_PATH=/home/user/go/bin/subfinder
# HTTPX_PATH=/home/user/go/bin/httpx

# ── Performance Tuning ────────────────────────────────────
MAX_CONCURRENT_PROGRAMS=3
SUBFINDER_TIMEOUT=300
CRTSH_RETRIES=3

# Jitter range in seconds — randomises request timing to avoid WAF detection
RATE_LIMIT_MIN_JITTER=0.5
RATE_LIMIT_MAX_JITTER=2.5

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/zeropoint.log

# ── Prober (Module 2) ─────────────────────────────────────
PROBER_BATCH_SIZE=200
PROBER_THREADS=50
PROBER_RATE_LIMIT=150
PROBER_TIMEOUT=10
PROBER_RETRIES=2
PROBER_REPROBE_HOURS=24
PROBER_FOLLOW_REDIRECTS=true
PROBER_SCREENSHOT=false

# ── Scanner (Module 3 — Nuclei) ───────────────────────────
# Step 1: Clone template repos alongside your project:
#   git clone https://github.com/projectdiscovery/nuclei-templates.git
#   git clone https://github.com/projectdiscovery/nuclei-templates-community.git
#   git clone https://github.com/projectdiscovery/fuzzing-templates.git
#
# Step 2: Point these paths at your cloned dirs (or leave empty for auto-managed):
NUCLEI_TEMPLATES_PATH=/path/to/nuclei-templates
NUCLEI_COMMUNITY_TEMPLATES_PATH=/path/to/nuclei-templates-community
NUCLEI_CUSTOM_TEMPLATES=/path/to/your-custom-templates
NUCLEI_FUZZING_TEMPLATES_PATH=/path/to/nuclei-templates/fuzzing
NUCLEI_ENABLE_FUZZING=true

# All severities alert immediately — dedup prevents re-alerts on the same finding
NUCLEI_SEVERITY=critical,high,medium,low,info
NUCLEI_RATE_LIMIT=50
NUCLEI_CONCURRENCY=25
NUCLEI_BULK_SIZE=25
NUCLEI_TIMEOUT=600
NUCLEI_RETRIES=1
NUCLEI_BATCH_SIZE=50
NUCLEI_RESCAN_HOURS=72
NUCLEI_INCLUDE_TAGS=
# dos excluded for safety; fuzz is handled via NUCLEI_ENABLE_FUZZING above
NUCLEI_EXCLUDE_TAGS=dos
SCANNER_MIN_INTEREST=high