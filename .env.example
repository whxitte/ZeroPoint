# ============================================================
# ZeroPoint — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── MongoDB Atlas ─────────────────────────────────────────
# Free-tier cluster URI from: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=zeropoint

# ── API Keys ──────────────────────────────────────────────
SHODAN_API_KEY=your_shodan_api_key_here

# Optional — improves Subfinder source coverage
GITHUB_TOKEN=ghp_xxxxxxxxxxxx
VIRUSTOTAL_KEY=your_virustotal_key_here
CENSYS_ID=your_censys_id
CENSYS_SECRET=your_censys_secret

# ── Notifications (at least one recommended) ──────────────
# Discord: Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxx/yyyy

# Telegram: BotFather to create bot, get chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxyz
TELEGRAM_CHAT_ID=-1001234567890

# ── Tool Binary Paths ─────────────────────────────────────
# Only set these if the binaries are not on your PATH
# SUBFINDER_PATH=/home/user/go/bin/subfinder
# HTTPX_PATH=/home/user/go/bin/httpx

# ── Performance Tuning ────────────────────────────────────
MAX_CONCURRENT_PROGRAMS=3
SUBFINDER_TIMEOUT=300
CRTSH_RETRIES=3

# Jitter range in seconds — randomises request timing to avoid WAF detection
RATE_LIMIT_MIN_JITTER=0.5
RATE_LIMIT_MAX_JITTER=2.5

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/zeropoint.log
