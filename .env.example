# ============================================================
# ZeroPoint — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── MongoDB Atlas ─────────────────────────────────────────
# Free-tier cluster URI from: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=zeropoint

# ── API Keys ──────────────────────────────────────────────
SHODAN_API_KEY=your_shodan_api_key_here
GITHUB_TOKEN=ghp_your_token_here

# For google dorking
GOOGLE_API_KEY=AIzaSy...
GOOGLE_CSE_ID=abc123...
BRAVE_SEARCH_API_KEY=BSA... # # $5/month free = 1,000 searches at $5/1,000
SERPAPI_KEY=your_key_here

# Optional — improves Subfinder source coverage
VIRUSTOTAL_KEY=your_virustotal_key_here
CENSYS_ID=your_censys_id
CENSYS_SECRET=your_censys_secret
IPINFO_TOKEN=your_ipinfo_token_here

# ── Notifications (at least one recommended) ──────────────
# Discord: Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxx/yyyy

# Telegram: BotFather to create bot, get chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxyz
TELEGRAM_CHAT_ID=-1001234567890

# ── Tool Binary Paths ─────────────────────────────────────
# Only set these if the binaries are not on your PATH
# SUBFINDER_PATH=/home/user/go/bin/subfinder
# HTTPX_PATH=/home/user/go/bin/httpx

# ── Performance Tuning ────────────────────────────────────
MAX_CONCURRENT_PROGRAMS=3
SUBFINDER_TIMEOUT=300
CRTSH_RETRIES=3
SHODAN_TIMEOUT=90
GITHUB_OSINT_RATE_DELAY=6.0    # 6s = ~10 queries/min, well under GitHub's secondary rate limit

# Jitter range in seconds — randomises request timing to avoid WAF detection
RATE_LIMIT_MIN_JITTER=0.5
RATE_LIMIT_MAX_JITTER=2.5

# ── Permutation Tuning (Module 1b — dnsgen + massdns) ────
# massdns queries per second. ⚠️  Keep ≤2000 on home connections — higher
# rates flood your router's NAT/DNS table and break ALL DNS on your network.
# On a server with a direct uplink you can safely use 5000+.
PERMUTATION_RATE=2000
# Hard cap on candidate permutations generated by dnsgen (memory guard)
PERMUTATION_MAX_CANDIDATES=500000
# Optional: absolute path to a custom wordlist for dnsgen (leave blank for built-in)
PERMUTATION_WORDLIST=

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/zeropoint.log

# ── subdomain permutation enable or disable (Module 1) ─────────────────────────────────────
PERMUTATION_ENABLED=true
MASSDNS_PATH=massdns

# ── Prober (Module 2) ─────────────────────────────────────
PROBER_BATCH_SIZE=200
PROBER_THREADS=50
PROBER_RATE_LIMIT=150
PROBER_TIMEOUT=10
PROBER_RETRIES=2
PROBER_REPROBE_HOURS=24
PROBER_FOLLOW_REDIRECTS=true
PROBER_SCREENSHOT=false

# ── Scanner (Module 3 — Nuclei) ───────────────────────────
# Step 1: Clone template repos alongside your project:
#   git clone https://github.com/projectdiscovery/nuclei-templates.git
#   git clone https://github.com/projectdiscovery/nuclei-templates-community.git
#   git clone https://github.com/projectdiscovery/fuzzing-templates.git
#
# Step 2: Point these paths at your cloned dirs (or leave empty for auto-managed):
NUCLEI_TEMPLATES_PATH=/path/to/nuclei-templates
NUCLEI_COMMUNITY_TEMPLATES_PATH=/path/to/nuclei-templates-community
NUCLEI_CUSTOM_TEMPLATES=/path/to/your-custom-templates
NUCLEI_FUZZING_TEMPLATES_PATH=/path/to/nuclei-templates/fuzzing
NUCLEI_ENABLE_FUZZING=true

# All severities alert immediately — dedup prevents re-alerts on the same finding
NUCLEI_SEVERITY=critical,high,medium,low,info
NUCLEI_RATE_LIMIT=50
NUCLEI_CONCURRENCY=25
NUCLEI_BULK_SIZE=25
NUCLEI_TIMEOUT=600
NUCLEI_RETRIES=1
NUCLEI_BATCH_SIZE=50
NUCLEI_RESCAN_HOURS=72
NUCLEI_INCLUDE_TAGS=

# parallel batch processing (Run 3 batches at once)
NUCLEI_PARALLEL_BATCHES=3

# dos excluded for safety; fuzz is handled via NUCLEI_ENABLE_FUZZING above
NUCLEI_EXCLUDE_TAGS=dos
SCANNER_MIN_INTEREST=high

KATANA_PATH=katana
WAYBACKURLS_PATH=waybackurls
GAU_PATH=gau
SECRETFINDER_PATH=/opt/SecretFinder/SecretFinder.py   # leave empty to skip

CRAWLER_DEPTH=3
CRAWLER_PARALLELISM=10
CRAWLER_RATE_LIMIT=50
CRAWLER_BATCH_SIZE=20
CRAWLER_PARALLEL_BATCHES=3
CRAWLER_RECRAWL_HOURS=48
CRAWLER_JS_ANALYSIS=true
CRAWLER_WAYBACK=true
CRAWLER_GAU=true
# If you want faster targeted crawls, change it in your .env: CRAWLER_MIN_INTEREST=high
CRAWLER_MIN_INTEREST=medium
SECRET_MIN_ENTROPY=3.5

# ── Orchestrator / Daemon (Module 5) ──────────────────────────────────────────
# Interval in seconds between each module's runs in daemon mode
DAEMON_INGEST_INTERVAL=3600    # 1 hour  — subdomain discovery
DAEMON_PROBE_INTERVAL=7200     # 2 hours — HTTP probe + fingerprint
DAEMON_SCAN_INTERVAL=21600     # 6 hours — Nuclei vulnerability scan
DAEMON_CRAWL_INTERVAL=43200    # 12 hours — endpoint crawl + JS secrets

# ── API / CORS ─────────────────────────────────────────────
API_CORS_ORIGINS=http://localhost:8080